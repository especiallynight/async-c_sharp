<Window x:Class="EmployeeManagement.EditEmployeeWindow"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:EmployeeManagement"
      mc:Ignorable="d"
      Title="EditEmployeeWindow" Height="552" Width="836">

    <Grid Margin="0,0,-116,36">
        <UIElement.RenderTransform>
            <TransformGroup>
                <ScaleTransform/>
                <SkewTransform/>
                <RotateTransform/>
                <TranslateTransform/>
            </TransformGroup>
        </UIElement.RenderTransform>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Фамилия:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="10"/>
        <TextBox Grid.Row="0" Grid.Column="1" x:Name="LastNameTextBox" Padding="5" Margin="10,10,621,10" Height="27"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Имя:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="10"/>
        <TextBox Grid.Row="1" x:Name="FirstNameTextBox" Padding="5" Margin="10,10,621,10" Height="27" Grid.Column="1"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Отчество:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="10"/>
        <TextBox Grid.Row="2" Grid.Column="1" x:Name="PatronymicTextBox" Padding="5" Margin="10,10,621,10" Height="27"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Дата рождения:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="10"/>
        <DatePicker Grid.Row="3" Grid.Column="1" x:Name="BirthDatePicker" Margin="10,10,621,10" Height="27"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Отдел:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="10"/>
        <TextBox Grid.Row="4" Grid.Column="1" x:Name="DepartmentTextBox" Padding="5" Margin="10,10,621,10" Height="27"/>

        <TextBlock Grid.Row="5" Grid.Column="0" Text="Адрес проживания:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="10"/>
        <TextBox Grid.Row="5" Grid.Column="1" x:Name="AddressTextBox" Padding="5" Margin="10,10,621,10" Height="27"/>

        <TextBlock Grid.Row="6" Grid.Column="0" Text="О себе:" FontWeight="SemiBold" VerticalAlignment="Top" Margin="10"/>
        <TextBox Grid.Row="6" Grid.Column="1" x:Name="AboutMeTextBox" Padding="5" Margin="10,10,621,10" Height="80" TextWrapping="Wrap"/>

        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,655,-6" Grid.ColumnSpan="2">
            <Button Content="Сохранить" Width="100" Height="30" Margin="5" Click="SaveButton_Click" RenderTransformOrigin="-0.918,-0.777"/>
            <Button Content="Отменить" Width="100" Height="30" Margin="5" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
